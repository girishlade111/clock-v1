{
  "name": "clock-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "expo-notifications": "~0.28.0",
    "expo-device": "~6.0.0",
    "expo-constants": "~16.0.0",
    "expo-background-task": "~1.11.0",
    "expo-task-manager": "~11.8.0",
    "expo-audio": "~0.3.0",
    "expo-haptics": "~12.10.0",
    "expo-localization": "~15.0.0",
    "expo-screen-orientation": "~7.0.0",
    "expo-system-ui": "~3.0.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-skia": "~0.1.220",
    "react-native-mmkv": "~2.12.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.0",
    "zustand": "^4.5.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.0.0",
    "intl-tzdb": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "typescript": "~5.3.3",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.0.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.0"
  },
  "private": true,
  "expo": {
    "name": "Clock",
    "slug": "clock-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clockapp.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "background-fetch", "remote-notification"],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.clockapp.app",
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-audio",
      "expo-screen-orientation",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-localization",
        {
          "skipLocales": ["all"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}